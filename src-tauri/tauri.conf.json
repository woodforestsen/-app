{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri-v2/main/.schemas/tauri.conf.schema.json",
  "productName": "黑马记账",
  "version": "1.0.0",
  "identifier": "com.heimajizhang.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "黑马记账",
        "width": 900,
        "height": 650,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
